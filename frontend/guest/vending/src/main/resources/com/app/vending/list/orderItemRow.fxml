<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<HBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.app.vending.controller.list.OrderItemRowController"
      alignment="CENTER_LEFT"
      spacing="12"
      style="
          -fx-background-color:white;
          -fx-background-radius:12;
          -fx-border-color:#E5E7EB;
          -fx-border-radius:12;
          -fx-border-width:1;
      ">

    <padding>
        <Insets top="12" right="14" bottom="12" left="14"/>
    </padding>

    <!-- Tên sản phẩm -->
    <Label fx:id="lblName"
           HBox.hgrow="ALWAYS"
           maxWidth="1.7976931348623157E308"
           text="Tên sản phẩm"
           style="
               -fx-font-size:14px;
               -fx-font-weight:bold;
               -fx-text-fill:#222222;
           "/>

    <!-- Số lượng -->
    <Label fx:id="lblQty"
           alignment="CENTER"
           minWidth="40"
           style="
               -fx-background-color:#F1F3F5;
               -fx-background-radius:8;
               -fx-padding:4 10;
               -fx-font-size:13px;
               -fx-font-weight:bold;
               -fx-text-fill:#1976D2;
           "
           text="x1"/>

    <!-- Thành tiền -->
    <Label fx:id="lblSubtotal"
           alignment="CENTER_RIGHT"
           minWidth="80"
           style="
               -fx-font-size:14px;
               -fx-font-weight:bold;
               -fx-text-fill:#1976D2;
           "
           text="20.000đ"/>

</HBox>