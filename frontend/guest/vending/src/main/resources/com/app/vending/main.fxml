<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.app.vending.controller.MainController"
            prefWidth="400"
            prefHeight="800"
            style="-fx-background-color:#F5F7FA;">

    <!-- HEADER -->
    <top>

        <HBox alignment="CENTER"
              prefHeight="60"
              style="-fx-background-color:#1976D2;">

            <Label text="SMART VENDING MACHINE"
                   style="
                        -fx-font-size:20px;
                        -fx-font-weight:bold;
                        -fx-text-fill:white;
                   "/>

        </HBox>

    </top>

    <!-- DANH SÁCH SẢN PHẨM -->
    <center>

        <ScrollPane fitToWidth="true"
                    hbarPolicy="NEVER"
                    style="
                        -fx-background:transparent;
                        -fx-background-color:transparent;
                    ">

            <VBox alignment="TOP_CENTER">

                <padding>
                    <Insets top="18" right="16" bottom="18" left="16"/>
                </padding>

                <GridPane fx:id="productGrid"
                          alignment="TOP_CENTER"
                          hgap="14"
                          vgap="14"/>

            </VBox>

        </ScrollPane>

    </center>

    <!-- FOOTER -->
    <bottom>

        <VBox spacing="12"
              alignment="CENTER"
              style="
                    -fx-background-color:white;
                    -fx-border-color:#E5E7EB;
                    -fx-border-width:1 0 0 0;
              ">

            <padding>
                <Insets top="14" right="18" bottom="18" left="18"/>
            </padding>

            <Label fx:id="lblTotal"
                   text="Tổng: 0 VNĐ"
                   style="
                        -fx-font-size:18px;
                        -fx-font-weight:bold;
                        -fx-text-fill:#1976D2;
                   "/>

            <Button text="TẠO ĐƠN HÀNG"
                    onAction="#handleCreateOrder"
                    prefWidth="240"
                    prefHeight="48"
                    style="
                        -fx-background-color:#1976D2;
                        -fx-text-fill:white;
                        -fx-font-size:15px;
                        -fx-font-weight:bold;
                        -fx-background-radius:12;
                        -fx-cursor:hand;
                    "/>

        </VBox>

    </bottom>

</BorderPane>