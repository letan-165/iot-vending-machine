<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.app.vending.controller.list.ProductCardController"
      alignment="TOP_CENTER"
      prefWidth="170"
      prefHeight="220"
      spacing="10"
      style="
          -fx-background-color:white;
          -fx-background-radius:16;
          -fx-border-color:#E5E7EB;
          -fx-border-radius:16;
          -fx-border-width:1;
      ">

    <padding>
        <Insets top="15" right="12" bottom="15" left="12"/>
    </padding>

    <!-- Ảnh -->
    <StackPane prefHeight="90"
               style="
                   -fx-background-color:#F8F9FA;
                   -fx-background-radius:12;
               ">

        <ImageView fx:id="imgProduct"
                   fitWidth="72"
                   fitHeight="72"
                   preserveRatio="true"/>

    </StackPane>

    <!-- Tên -->
    <Label fx:id="lblName"
           text="Tên sản phẩm"
           wrapText="true"
           maxWidth="145"
           alignment="CENTER"
           style="
               -fx-font-size:14px;
               -fx-font-weight:bold;
               -fx-text-fill:#222222;
           "/>

    <!-- Giá -->
    <Label fx:id="lblPrice"
           text="0 VNĐ"
           style="
               -fx-font-size:13px;
               -fx-font-weight:bold;
               -fx-text-fill:#1976D2;
           "/>

    <Region VBox.vgrow="ALWAYS"/>

    <!-- Điều chỉnh số lượng -->
    <HBox alignment="CENTER"
          spacing="10">

        <Button text="−"
                onAction="#handleMinus"
                prefWidth="34"
                prefHeight="34"
                style="
                    -fx-background-color:#F1F3F5;
                    -fx-background-radius:8;
                    -fx-font-size:16px;
                    -fx-font-weight:bold;
                    -fx-cursor:hand;
                "/>

        <Label fx:id="lblQty"
               text="0"
               prefWidth="40"
               alignment="CENTER"
               style="
                   -fx-font-size:16px;
                   -fx-font-weight:bold;
                   -fx-text-fill:#222222;
               "/>

        <Button text="+"
                onAction="#handlePlus"
                prefWidth="34"
                prefHeight="34"
                style="
                    -fx-background-color:#1976D2;
                    -fx-text-fill:white;
                    -fx-background-radius:8;
                    -fx-font-size:16px;
                    -fx-font-weight:bold;
                    -fx-cursor:hand;
                "/>

    </HBox>

</VBox>